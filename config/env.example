# Example environment for ghbak (systemd EnvironmentFile)
# Copy to: ~/.config/ghbak/env

# Required
ORG=example-org

# Optional
# INCLUDE_WIKI=1
# GIT_PROTOCOL=ssh     # ssh|https
# LFS_MODE=always      # always|auto|never
# SNAPSHOT_MODE=none   # none|restic

# Restic (only if SNAPSHOT_MODE=restic)
# RESTIC_REPOSITORY=/home/YOU/Backups/restic/github-example-org
# RESTIC_PASSWORD_FILE=/home/YOU/.config/restic/github-example-org.pass
# RESTIC_KEEP_DAILY=30
# RESTIC_KEEP_WEEKLY=12
# RESTIC_KEEP_MONTHLY=12
